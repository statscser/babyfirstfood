<!-- index.wxml — Baby's First 100 Foods -->
<view class="page">

  <!-- ==================== 顶部标题栏 ==================== -->
  <view class="header">
    <view class="header-sparkle">🍼</view>
    <view class="header-text">
      <text class="header-title">宝宝食物初体验</text>
      <text class="header-sub">Baby's First 100 Foods</text>
    </view>
    <view class="header-badge">
      <text class="header-badge-num">{{triedCount}}</text>
      <text class="header-badge-total">/{{totalCount}}</text>
    </view>
    <view class="header-share" bindtap="onShareTap">
      <text class="header-share-icon">📤</text>
    </view>
  </view>

  <!-- ==================== 搜索栏 ==================== -->
  <view class="search-wrap">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索食物名称..."
        placeholder-class="search-placeholder"
        value="{{searchValue}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <text wx:if="{{searchValue}}" class="search-clear" bindtap="onSearchClear">✕</text>
    </view>
  </view>

  <!-- ==================== 今日待办 ==================== -->
  <view wx:if="{{todayTasks.length > 0}}" class="today-section">
    <text class="today-section-title">今日待办 : {{todayTasks.length}}</text>
    <scroll-view scroll-x class="today-scroll" show-scrollbar="{{false}}">
      <view class="today-cards-row">
        <view
          wx:for="{{todayTasks}}"
          wx:key="{{item.food.id}}"
          class="today-card {{item.isInterrupted ? 'today-card-interrupted' : (item.isTodayDone ? 'today-card-done' : 'today-card-active')}}"
          style="border-left-color:{{item.accentColor}}"
          bindtap="onTodayTaskTap"
          data-id="{{item.food.id}}"
        >
          <text class="today-emoji">{{item.food.emoji}}</text>
          <view class="today-body">
            <text wx:if="{{item.isInterrupted}}"  class="today-title today-title-warn">⚠️ {{item.food.name}} 排敏中断</text>
            <text wx:elif="{{item.isTodayDone}}"  class="today-title today-title-done">✓ 今日 {{item.food.name}} 已完成</text>
            <text wx:else                          class="today-title">今天是 {{item.food.name}} 排敏的第 {{item.dayNum}} 天</text>

            <text wx:if="{{item.isInterrupted}}"  class="today-sub">上次记录：{{item.lastDate}}，建议重新开始 3 天流程</text>
            <text wx:elif="{{item.isTodayDone}}"  class="today-sub">明天再来记录第 {{item.dayNum}} 天</text>
            <text wx:else                          class="today-sub">点击开始今日记录 →</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ==================== 分类 Tab ==================== -->
  <scroll-view class="tabs-scroll" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tabs-inner">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="tab-item {{activeTab === index ? 'tab-active' : ''}}"
        style="{{activeTab === index ? 'background:' + themeColor + ';border-color:' + themeColor : ''}}"
        bindtap="onTabChange"
        data-idx="{{index}}"
      >
        <text class="tab-label">{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- ==================== 数量提示 + 排序 ==================== -->
  <view class="count-bar">
    <text class="count-text" style="color:{{themeColor}}">{{displayFoods.length}} 种食物清单</text>
    <view class="sort-wrap">
      <view class="sort-picker" style="border-color:{{themeColor}}" catchtap="onSortToggle">
        <text class="sort-picker-label" style="color:{{themeColor}}">{{sortOptions[sortIndex].label}}</text>
        <text class="sort-picker-arrow" style="color:{{themeColor}}">{{sortOpen ? '▴' : '▾'}}</text>
      </view>
      <view wx:if="{{sortOpen}}" class="sort-dropdown" catchtap="preventBubble">
        <view
          wx:for="{{sortOptions}}"
          wx:key="mode"
          class="sort-option {{sortIndex === index ? 'sort-option-active' : ''}}"
          style="{{sortIndex === index ? 'color:' + themeColor : ''}}"
          catchtap="onSortSelect"
          data-index="{{index}}"
        >{{item.label}}</view>
      </view>
    </view>
  </view>

  <!-- ==================== 排序下拉关闭遮罩 ==================== -->
  <view wx:if="{{sortOpen}}" class="sort-mask" bindtap="onSortClose"></view>

  <!-- ==================== 遮罩 ==================== -->
  <view class="mask {{activeId ? 'mask-show' : ''}}" bindtap="onMaskTap"></view>

  <!-- ==================== 详情 Overlay ==================== -->
  <!--
    3D 翻转容器留在 index；卡片背面内容由 food-detail 组件负责。
    overlay-wrap: scale(0.15→1) + opacity
    overlay-inner: rotateY(0→180deg)
  -->
  <view
    wx:if="{{activeFood}}"
    class="overlay-wrap {{activeId ? 'overlay-active' : ''}}"
    catchtap="preventBubble"
  >
    <view class="overlay-inner">

      <!-- 正面（过渡短暂可见） -->
      <view class="overlay-face overlay-front card-bg-{{activeFood.categoryKey}}">
        <text class="food-emoji large">{{activeFood.emoji}}</text>
        <text class="food-name">{{activeFood.name}}</text>
        <text class="food-en">{{activeFood.en}}</text>
      </view>

      <!-- 背面 → food-detail 组件 -->
      <view class="overlay-face overlay-back">
        <food-detail
          food="{{activeFood}}"
          bind:save="onSaveRecord"
          bind:close="onMaskTap"
        />
      </view>

    </view>
  </view>

  <!-- ==================== 食物网格 ==================== -->
  <view class="grid-wrap">
    <view wx:if="{{displayFoods.length === 0}}" class="empty-state">
      <text class="empty-emoji">🌱</text>
      <text class="empty-text">暂无匹配的食物</text>
    </view>

    <view class="food-grid">
      <view
        wx:for="{{displayFoods}}"
        wx:key="id"
        class="food-card card-bg-{{item.categoryKey}}"
        bindtap="onCardTap"
        data-id="{{item.id}}"
      >
        <text wx:if="{{item.likeEmoji}}" class="card-like-emoji">{{item.likeEmoji}}</text>
        <text class="food-emoji">{{item.emoji}}</text>
        <text class="food-name">{{item.name}}</text>
        <text class="food-en">{{item.en}}</text>
        <view class="dots-row">
          <view
            wx:for="{{item.dots}}"
            wx:key="index"
            wx:for-item="dot"
            wx:for-index="di"
            class="dot {{dot.cls}}"
          ></view>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 分享海报组件 ==================== -->
  <share-poster
    visible="{{posterVisible}}"
    allFoods="{{allFoods}}"
    triedCount="{{triedCount}}"
    totalCount="{{totalCount}}"
    bind:close="onClosePoster"
  />

</view>
