/* =======================================================
   index.wxss — 莫兰迪色系 + Overlay 翻转展开卡片
   ======================================================= */

/* ---------- 页面容器 ---------- */
.page {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: 60rpx;
}

/* =======================================================
   顶部标题栏
   ======================================================= */
.header {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  background-color: var(--header-bg);
  gap: 16rpx;
}

.header-sparkle { font-size: 36rpx; line-height: 1; }

.header-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.header-sub {
  font-size: 22rpx;
  color: var(--text-en);
  letter-spacing: 1rpx;
  font-style: italic;
}

.header-badge {
  display: flex;
  align-items: baseline;
  background-color: var(--header-pink);
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
  gap: 2rpx;
}

.header-badge-num  { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }
.header-badge-total { font-size: 22rpx; color: var(--text-secondary); }

/* =======================================================
   搜索栏
   ======================================================= */
.search-wrap {
  padding: 16rpx 24rpx 8rpx;
  background-color: var(--header-bg);
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #f0ebe8;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  gap: 12rpx;
}

.search-icon    { font-size: 28rpx; opacity: 0.6; flex-shrink: 0; }
.search-input   { flex: 1; font-size: 28rpx; color: var(--text-primary); background: transparent; }
.search-placeholder { color: var(--text-en); font-size: 28rpx; }
.search-clear   { font-size: 24rpx; color: var(--text-secondary); padding: 4rpx 8rpx; flex-shrink: 0; }

/* =======================================================
   分类 Tab
   ======================================================= */
.tabs-scroll {
  background-color: var(--header-bg);
  padding-bottom: 16rpx;
  white-space: nowrap;
}

.tabs-inner {
  display: flex;
  flex-direction: row;
  padding: 12rpx 24rpx 0;
  gap: 16rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  border: 2rpx solid #e0d8d4;
  background-color: var(--bg-card);
  flex-shrink: 0;
  transition: all 0.2s;
}

.tab-label          { font-size: 26rpx; color: var(--text-secondary); font-weight: 500; }
.tab-active .tab-label { color: #ffffff; font-weight: 600; }

/* =======================================================
   数量提示
   ======================================================= */
.count-bar   { padding: 16rpx 32rpx 8rpx; }
.count-text  { font-size: 24rpx; font-weight: 500; letter-spacing: 1rpx; }

/* =======================================================
   遮罩
   ======================================================= */
.mask {
  display: none;
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(30, 20, 20, 0.5);
  z-index: 100;
}
.mask-show { display: block; }

/* =======================================================
   Overlay 包装器
   扩张动画：scale(0.15) → scale(1) 同时 opacity 0→1
   翻转动画：overlay-inner rotateY 0 → 180deg（略有延迟）
   ======================================================= */
.overlay-wrap {
  position: fixed;
  top: 4vh;
  left: 5vw;
  width: 90vw;
  height: 90vh;
  z-index: 200;
  border-radius: 32rpx;
  /* 起始：缩小 + 透明，模拟从网格卡飞出的效果 */
  transform: scale(0.15);
  opacity: 0;
  pointer-events: none;
  transition:
    transform 0.46s cubic-bezier(0.22, 1, 0.36, 1),
    opacity   0.24s ease;
  /* perspective 放在此层，card-inner 才能正确 preserve-3d */
  perspective: 1400rpx;
}

.overlay-wrap.overlay-active {
  transform: scale(1);
  opacity: 1;
  pointer-events: auto;
}

/* 翻转体 */
.overlay-inner {
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
  transform-style: preserve-3d;
  -webkit-transform-style: preserve-3d;
  /* 翻转延迟 0.12s，让卡片先扩张一点再开始翻 */
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.12s;
}

.overlay-wrap.overlay-active .overlay-inner {
  transform: rotateY(180deg);
  -webkit-transform: rotateY(180deg);
}

/* 正背面公共基础 */
.overlay-face {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 32rpx;
  overflow: hidden;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

/* 正面 */
.overlay-front {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

/* 背面：初始旋转 180deg（隐藏），翻转后可见 */
.overlay-back {
  transform: rotateY(180deg);
  -webkit-transform: rotateY(180deg);
  background: #fffdf9;
  display: flex;
  flex-direction: column;
  box-shadow: 0 24rpx 80rpx rgba(60, 40, 40, 0.22);
}

/* =======================================================
   分类背景染色
   ======================================================= */
.card-bg-vegetables { background-color: var(--bg-vegetables); }
.card-bg-fruits     { background-color: var(--bg-fruits);     }
.card-bg-grains     { background-color: var(--bg-grains);     }
.card-bg-meat       { background-color: var(--bg-meat);       }
.card-bg-dairy      { background-color: var(--bg-dairy);      }
.card-bg-legumes    { background-color: var(--bg-legumes);    }
.card-bg-nuts       { background-color: var(--bg-nuts);       }
.card-bg-spices     { background-color: var(--bg-spices);     }

/* =======================================================
   食物网格 & 卡片（正面，无翻转结构）
   ======================================================= */
.grid-wrap { padding: 0 20rpx; }

.food-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx;
}

.food-card {
  width: calc((100% - 40rpx) / 3);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx 16rpx;
  border-radius: var(--card-radius);
  box-shadow: var(--card-shadow);
  box-sizing: border-box;
}

/* --- 卡片正面内容 --- */
.food-emoji       { font-size: 56rpx; line-height: 1; margin-bottom: 10rpx; }
.food-emoji.large { font-size: 80rpx; }

.food-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  text-align: center;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 4rpx;
}

.food-en {
  font-size: 20rpx;
  color: var(--text-en);
  text-align: center;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 14rpx;
}

/* --- 进度圆点 --- */
.dots-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}

.dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-empty  { background-color: var(--dot-empty); }
.dot-rose   { background-color: var(--dot-rose);  box-shadow: 0 0 0 2rpx rgba(212,144,140,.25); }
.dot-amber  { background-color: var(--dot-amber); box-shadow: 0 0 0 2rpx rgba(212,184,120,.25); }
.dot-sage   { background-color: var(--dot-sage);  box-shadow: 0 0 0 2rpx rgba(138,180,138,.25); }

/* =======================================================
   背面：标题区
   ======================================================= */
.back-header {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 22rpx;
  gap: 18rpx;
  flex-shrink: 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.back-emoji { font-size: 64rpx; line-height: 1; flex-shrink: 0; }

.back-title-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.back-name { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }
.back-en   { font-size: 24rpx; color: var(--text-en); font-style: italic; }

.back-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.07);
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

/* =======================================================
   背面：主体区
   ======================================================= */
.back-body {
  flex: 1;
  padding: 24rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  overflow: hidden;
}

.back-section {
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 2rpx;
  margin-bottom: 14rpx;
}

/* =======================================================
   喂食记录槽
   ======================================================= */
.slots-wrap {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.slot {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* 数字徽章：颜色由实际记录结果决定，未记录时为中性灰 */
.slot-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

.slot-badge-empty    { background: #c4bcb8; }                  /* 未记录：中性灰 */
.slot-badge-safe     { background: var(--dot-sage);  }          /* 安全通过：鼠尾草绿 */
.slot-badge-caution  { background: var(--dot-amber); }          /* 轻微反应：琥珀黄 */
.slot-badge-allergic { background: var(--dot-rose);  }          /* 过敏反应：玫瑰红 */

.slot-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.slot-label { font-size: 26rpx; font-weight: 600; color: var(--text-primary); }
.slot-date  { font-size: 22rpx; color: var(--text-secondary); }
.slot-arrow { font-size: 32rpx; color: var(--text-en); flex-shrink: 0; }

/* =======================================================
   喜好度
   ======================================================= */
.like-scale {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
}

.like-btn {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

/* =======================================================
   文字备注
   ======================================================= */
.note-input {
  width: 100%;
  min-height: 88rpx;
  background: rgba(255, 255, 255, 0.75);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  font-size: 26rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.note-placeholder { color: var(--text-en); font-size: 26rpx; }

/* =======================================================
   空状态
   ======================================================= */
.empty-state {
  width: 100%;
  padding: 100rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.empty-emoji { font-size: 80rpx; }
.empty-text  { font-size: 28rpx; color: var(--text-secondary); }
