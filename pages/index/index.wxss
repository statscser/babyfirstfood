/* =======================================================
   index.wxss — 莫兰迪色系 + Overlay 3D 翻转容器 + 食物网格
   ======================================================= */

.page {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: 60rpx;
}

/* =======================================================
   顶部标题栏
   ======================================================= */
.header {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  background-color: var(--header-bg);
  gap: 16rpx;
}
.header-sparkle { font-size: 36rpx; line-height: 1; }
.header-text    { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.header-title   { font-size: 40rpx; font-weight: 700; color: var(--text-primary); letter-spacing: 2rpx; }
.header-sub     { font-size: 22rpx; color: var(--text-en); letter-spacing: 1rpx; font-style: italic; }
.header-badge   { display: flex; align-items: baseline; background-color: var(--header-pink); border-radius: 40rpx; padding: 8rpx 20rpx; gap: 2rpx; }
.header-badge-num   { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }
.header-badge-total { font-size: 22rpx; color: var(--text-secondary); }
.header-share { width: 68rpx; height: 68rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

/* ── Share icon: three colored dots + two lines ── */
.share-icon     { width: 44rpx; height: 44rpx; position: relative; }
.si-dot         { position: absolute; width: 14rpx; height: 14rpx; border-radius: 50%; }
.si-dot-left    { left: 0; top: 50%; transform: translateY(-50%); background: #c4a8b0; }
.si-dot-top     { right: 0; top: 0;    background: #8fab8f; }
.si-dot-bottom  { right: 0; bottom: 0; background: #d4908c; }
.si-line {
  position: absolute;
  left: 7rpx; top: 22rpx; margin-top: -1rpx;
  width: 34rpx; height: 4rpx;
  background: rgba(196,168,176,0.45);
  transform-origin: 0 50%;
}
.si-line-top    { transform: rotate(-26.6deg); }
.si-line-bottom { transform: rotate(26.6deg); }

/* =======================================================
   搜索栏
   ======================================================= */
.search-wrap { padding: 16rpx 24rpx 8rpx; background-color: var(--header-bg); }
.search-bar  { display: flex; align-items: center; background-color: #f0ebe8; border-radius: 40rpx; padding: 16rpx 24rpx; gap: 12rpx; }
.search-icon  { font-size: 30rpx; opacity: 0.6; flex-shrink: 0; }
.search-input { flex: 1; font-size: 30rpx; color: var(--text-primary); background: transparent; }
.search-placeholder { color: var(--text-en); font-size: 30rpx; }
.search-clear { font-size: 24rpx; color: var(--text-secondary); padding: 4rpx 8rpx; flex-shrink: 0; }

/* =======================================================
   今日待办列表
   ======================================================= */
.today-section {
  margin: 16rpx 0 4rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.today-section-title {
  padding: 0 36rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: 1rpx;
}

/* 横向滚动容器 */
.today-scroll { padding: 4rpx 0 8rpx; }
.today-cards-row {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  padding: 0 24rpx;
  width: max-content;
}

.today-card {
  flex-shrink: 0;
  width: 520rpx;
  padding: 24rpx 12rpx 24rpx 24rpx;
  border-radius: 20rpx;
  border-left: 6rpx solid;
  background: var(--bg-card);
  box-shadow: var(--card-shadow);
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: opacity 0.12s;
}
.today-card:active { opacity: 0.75; }

.today-card-active      { background: #fffdf9; }
.today-card-done        { background: rgba(138,180,138,0.08); }
.today-card-interrupted { background: rgba(212,144,140,0.08); }

.today-emoji { font-size: 56rpx; line-height: 1; flex-shrink: 0; }

.today-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}
.today-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
}
.today-title-warn { color: #b05050; }
.today-title-done { color: #5a8a5a; }
.today-sub {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

/* =======================================================
   分类 Tab
   ======================================================= */
.tabs-scroll  { background-color: var(--header-bg); padding-top: 8rpx; padding-bottom: 16rpx; white-space: nowrap; }
.tabs-inner   { display: flex; flex-direction: row; padding: 12rpx 24rpx 0; gap: 16rpx; }
.tab-item     { display: inline-flex; align-items: center; justify-content: center; padding: 12rpx 28rpx; border-radius: 40rpx; border: 2rpx solid #e0d8d4; background-color: var(--bg-card); flex-shrink: 0; transition: all 0.2s; }
.tab-label    { font-size: 28rpx; color: var(--text-secondary); font-weight: 500; }
.tab-active .tab-label { color: #ffffff; font-weight: 600; }

/* =======================================================
   数量提示 + 排序
   ======================================================= */
.count-bar  { padding: 16rpx 32rpx 8rpx; display: flex; align-items: center; justify-content: space-between; }
.count-text { font-size: 26rpx; font-weight: 500; letter-spacing: 1rpx; }

/* 排序自定义下拉 */
.sort-mask {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 499;
}
.sort-wrap { position: relative; }
.sort-picker {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 18rpx;
  border-radius: 30rpx;
  border: 1.5rpx solid;
  background: rgba(255,255,255,0.6);
}
.sort-picker-label { font-size: 24rpx; font-weight: 600; letter-spacing: 1rpx; }
.sort-picker-arrow { font-size: 20rpx; }

.sort-dropdown {
  position: absolute;
  top: calc(100% + 10rpx);
  right: 0;
  background: #fffdf9;
  border-radius: 18rpx;
  box-shadow: 0 8rpx 36rpx rgba(60,40,40,0.16);
  z-index: 500;
  overflow: hidden;
  min-width: 180rpx;
}
.sort-option {
  padding: 22rpx 32rpx;
  font-size: 26rpx;
  color: var(--text-primary);
}
.sort-option-active {
  font-weight: 700;
  background: rgba(196,168,176,0.1);
}

/* =======================================================
   遮罩
   ======================================================= */
.mask      { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(30, 20, 20, 0.5); z-index: 100; }
.mask-show { display: block; }

/* =======================================================
   Overlay 3D 容器 — scale + flip（内容由 food-detail 组件提供）
   ======================================================= */
.overlay-wrap {
  position: fixed;
  /* top & height are set via JS (overlayStyle) using windowHeight to correctly
     exclude system bars on Android — do not set them here */
  left: 5vw;
  width: 90vw;
  z-index: 200;
  border-radius: 32rpx;
  perspective: 1400rpx;
  transform: scale(0.15);
  opacity: 0;
  pointer-events: none;
  transition:
    transform 0.46s cubic-bezier(0.22, 1, 0.36, 1),
    opacity   0.24s ease;
}
.overlay-wrap.overlay-active {
  transform: scale(1);
  opacity: 1;
  pointer-events: auto;
}

.overlay-inner {
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
  transform-style: preserve-3d;
  -webkit-transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.12s;
}
.overlay-wrap.overlay-active .overlay-inner {
  transform: rotateY(180deg);
  -webkit-transform: rotateY(180deg);
}

.overlay-face {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 32rpx;
  overflow: hidden;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}
.overlay-front {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.overlay-back {
  transform: rotateY(180deg);
  -webkit-transform: rotateY(180deg);
  background: #fffdf9;
  display: flex;
  flex-direction: column;
  box-shadow: 0 24rpx 80rpx rgba(60, 40, 40, 0.22);
}

/* =======================================================
   食物网格卡片（正面，仅用于网格展示）
   ======================================================= */
.card-bg-vegetables { background-color: var(--bg-vegetables); }
.card-bg-fruits     { background-color: var(--bg-fruits);     }
.card-bg-grains     { background-color: var(--bg-grains);     }
.card-bg-meat       { background-color: var(--bg-meat);       }
.card-bg-dairy      { background-color: var(--bg-dairy);      }
.card-bg-legumes    { background-color: var(--bg-legumes);    }
.card-bg-nuts       { background-color: var(--bg-nuts);       }
.card-bg-spices     { background-color: var(--bg-spices);     }

.grid-wrap { padding: 0 20rpx; }
.food-grid { display: flex; flex-direction: row; flex-wrap: wrap; gap: 20rpx; }

.food-card {
  width: calc((100% - 40rpx) / 3);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx 44rpx;
  border-radius: var(--card-radius);
  box-shadow: var(--card-shadow);
  box-sizing: border-box;
  position: relative;
}

/* Like emoji badge — top-right corner */
.card-like-emoji {
  position: absolute;
  top: 10rpx;
  right: 12rpx;
  font-size: 32rpx;
  line-height: 1;
}

.food-emoji       { font-size: 56rpx; line-height: 1; margin-bottom: 10rpx; }
.food-emoji.large { font-size: 80rpx; }
.food-name  { font-size: 30rpx; font-weight: 600; color: var(--text-primary); text-align: center; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 4rpx; }
.food-en    { font-size: 22rpx; line-height: 30rpx; min-height: 30rpx; color: var(--text-en); text-align: center; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 16rpx; display: block; }

/* ── Food attribute tag stripe — absolute bottom overlay ── */
.tag-stripe {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 30rpx;
  display: flex;
  overflow: hidden;
  border-radius: 0 0 var(--card-radius) var(--card-radius);
}
.tag-stripe-seg  { flex: 1; height: 100%; display: flex; align-items: center; justify-content: center; }
.tag-stripe-text { font-size: 18rpx; line-height: 1; letter-spacing: 0.5rpx; }
.tag-none        { background: #ede9e5; }
.tag-allergen    { background: #fff8e0; }
.tag-allergen .tag-stripe-text { color: #a07820; }
.tag-iron        { background: #fdecea; }
.tag-iron .tag-stripe-text     { color: #a03030; }
.tag-vc          { background: #fff3e0; }
.tag-vc .tag-stripe-text       { color: #b06020; }

.dots-row { display: flex; flex-direction: row; align-items: center; gap: 10rpx; }
.dot       { width: 24rpx; height: 24rpx; border-radius: 50%; flex-shrink: 0; }
.dot-empty  { background-color: var(--dot-empty); }
.dot-rose   { background-color: var(--dot-rose);  box-shadow: 0 0 0 2rpx rgba(212,144,140,.25); }
.dot-amber  { background-color: var(--dot-amber); box-shadow: 0 0 0 2rpx rgba(212,184,120,.25); }
.dot-sage   { background-color: var(--dot-sage);  box-shadow: 0 0 0 2rpx rgba(138,180,138,.25); }

/* =======================================================
   回到顶部
   ======================================================= */
@keyframes backTopIn {
  from { opacity: 0; transform: scale(0.7); }
  to   { opacity: 1; transform: scale(1);   }
}
.back-top {
  position: fixed;
  bottom: 120rpx; right: 32rpx;
  width: 80rpx; height: 80rpx;
  border-radius: 50%;
  background: rgba(196,168,176,0.88);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(196,168,176,0.45);
  z-index: 50;
  animation: backTopIn 0.22s cubic-bezier(0.34,1.56,0.64,1) both;
}
/* upward chevron drawn with two rotated borders */
.back-top-arrow {
  width: 20rpx; height: 20rpx;
  border-top: 3rpx solid #fff;
  border-right: 3rpx solid #fff;
  transform: rotate(-45deg);
  margin-top: 8rpx;
}

/* =======================================================
   意见反馈
   ======================================================= */
.feedback-wrap { display: flex; justify-content: center; padding: 32rpx 0 16rpx; }
.feedback-btn { background: transparent; border-radius: 40rpx; padding: 12rpx 40rpx; font-size: 24rpx; color: var(--text-secondary); line-height: 1.6; }
.feedback-btn::after { border: 1rpx solid rgba(0,0,0,0.1); border-radius: 40rpx; }

/* =======================================================
   自定义食物 Modal
   ======================================================= */
.cf-overlay {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: rgba(20,12,12,0.55); z-index: 700;
  display: flex; align-items: center; justify-content: center;
}
.cf-modal {
  width: 640rpx; background: #fdf8f5; border-radius: 32rpx;
  padding: 40rpx 36rpx 32rpx;
  display: flex; flex-direction: column; gap: 28rpx;
}
.cf-title  { font-size: 34rpx; font-weight: 700; color: var(--text-primary); text-align: center; }
.cf-field  { display: flex; flex-direction: column; gap: 10rpx; }
.cf-label  { font-size: 26rpx; font-weight: 600; color: var(--text-secondary); }
.cf-input  { background: rgba(0,0,0,0.04); border: 1.5rpx solid rgba(0,0,0,0.08); border-radius: 16rpx; padding: 18rpx 20rpx; font-size: 30rpx; color: var(--text-primary); }
.cf-picker { display: flex; align-items: center; justify-content: space-between; background: rgba(0,0,0,0.04); border: 1.5rpx solid rgba(0,0,0,0.08); border-radius: 16rpx; padding: 18rpx 20rpx; }
.cf-picker-text  { font-size: 30rpx; color: var(--text-primary); }
.cf-picker-arrow { font-size: 22rpx; color: var(--text-secondary); }
/* ── Modal tag picker ── */
.cf-tags-row { display: flex; gap: 14rpx; flex-wrap: wrap; margin-top: 6rpx; }
.cf-tag      { border-radius: 30rpx; border: 1.5rpx solid #e0d8d4; padding: 10rpx 28rpx; }
.cf-tag-text { font-size: 26rpx; color: #a09890; }
.cf-tag-active { border-color: transparent; }
.cf-tag-allergen            { background: #fff8e0; }
.cf-tag-allergen .cf-tag-text { color: #a07820; font-weight: 600; }
.cf-tag-iron                { background: #fdecea; }
.cf-tag-iron .cf-tag-text   { color: #a03030; font-weight: 600; }
.cf-tag-vc                  { background: #fff3e0; }
.cf-tag-vc .cf-tag-text     { color: #b06020; font-weight: 600; }

.cf-actions { display: flex; gap: 16rpx; margin-top: 4rpx; }
.cf-btn     { flex: 1; padding: 22rpx 0; border-radius: 20rpx; font-size: 30rpx; font-weight: 600; text-align: center; }
.cf-cancel  { background: rgba(0,0,0,0.05); color: var(--text-secondary); }
.cf-confirm { background: #c4a8b0; color: #fff; }

/* =======================================================
   空状态
   ======================================================= */
.empty-state    { width: 100%; padding: 80rpx 0; display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.empty-emoji    { font-size: 80rpx; }
.empty-text     { font-size: 28rpx; color: var(--text-secondary); text-align: center; }
.empty-hint     { font-size: 26rpx; color: var(--text-en); text-align: center; padding: 0 60rpx; line-height: 1.5; }
.empty-add-btn  { margin-top: 8rpx; padding: 20rpx 48rpx; background: #c4a8b0; border-radius: 40rpx; box-shadow: 0 4rpx 16rpx rgba(196,168,176,0.4); }
.empty-add-text { font-size: 28rpx; color: #fff; font-weight: 600; }

/* =======================================================
   首次启动提示横幅
   ======================================================= */
.notice-banner {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  background: rgba(80, 68, 64, 0.92);
  padding: 24rpx 32rpx 40rpx;
  gap: 20rpx;
}
.notice-text      { flex: 1; font-size: 22rpx; color: rgba(255,255,255,0.80); line-height: 1.7; }
.notice-close     { flex-shrink: 0; width: 44rpx; height: 44rpx; display: flex; align-items: center; justify-content: center; }
.notice-close-icon { font-size: 40rpx; color: rgba(255,255,255,0.55); line-height: 1; }

