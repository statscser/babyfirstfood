/* =======================================================
   index.wxss — 莫兰迪色系 + Overlay 翻转展开 + 记录交互
   ======================================================= */

.page {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: 60rpx;
}

/* =======================================================
   顶部标题栏
   ======================================================= */
.header {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  background-color: var(--header-bg);
  gap: 16rpx;
}
.header-sparkle { font-size: 36rpx; line-height: 1; }
.header-text    { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.header-title   { font-size: 40rpx; font-weight: 700; color: var(--text-primary); letter-spacing: 2rpx; }
.header-sub     { font-size: 22rpx; color: var(--text-en); letter-spacing: 1rpx; font-style: italic; }
.header-badge   { display: flex; align-items: baseline; background-color: var(--header-pink); border-radius: 40rpx; padding: 8rpx 20rpx; gap: 2rpx; }
.header-badge-num   { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }
.header-badge-total { font-size: 22rpx; color: var(--text-secondary); }

/* =======================================================
   搜索栏
   ======================================================= */
.search-wrap { padding: 16rpx 24rpx 8rpx; background-color: var(--header-bg); }
.search-bar  { display: flex; align-items: center; background-color: #f0ebe8; border-radius: 40rpx; padding: 16rpx 24rpx; gap: 12rpx; }
.search-icon  { font-size: 28rpx; opacity: 0.6; flex-shrink: 0; }
.search-input { flex: 1; font-size: 28rpx; color: var(--text-primary); background: transparent; }
.search-placeholder { color: var(--text-en); font-size: 28rpx; }
.search-clear { font-size: 24rpx; color: var(--text-secondary); padding: 4rpx 8rpx; flex-shrink: 0; }

/* =======================================================
   分类 Tab
   ======================================================= */
.tabs-scroll  { background-color: var(--header-bg); padding-bottom: 16rpx; white-space: nowrap; }
.tabs-inner   { display: flex; flex-direction: row; padding: 12rpx 24rpx 0; gap: 16rpx; }
.tab-item     { display: inline-flex; align-items: center; justify-content: center; padding: 12rpx 28rpx; border-radius: 40rpx; border: 2rpx solid #e0d8d4; background-color: var(--bg-card); flex-shrink: 0; transition: all 0.2s; }
.tab-label    { font-size: 26rpx; color: var(--text-secondary); font-weight: 500; }
.tab-active .tab-label { color: #ffffff; font-weight: 600; }

/* =======================================================
   数量提示
   ======================================================= */
.count-bar  { padding: 16rpx 32rpx 8rpx; }
.count-text { font-size: 24rpx; font-weight: 500; letter-spacing: 1rpx; }

/* =======================================================
   遮罩
   ======================================================= */
.mask      { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(30, 20, 20, 0.5); z-index: 100; }
.mask-show { display: block; }

/* =======================================================
   Overlay 包装器 — scale + flip
   ======================================================= */
.overlay-wrap {
  position: fixed;
  top: 4vh;
  left: 5vw;
  width: 90vw;
  height: 90vh;
  z-index: 200;
  border-radius: 32rpx;
  perspective: 1400rpx;
  /* initial state: tiny + invisible */
  transform: scale(0.15);
  opacity: 0;
  pointer-events: none;
  transition:
    transform 0.46s cubic-bezier(0.22, 1, 0.36, 1),
    opacity   0.24s ease;
}
.overlay-wrap.overlay-active {
  transform: scale(1);
  opacity: 1;
  pointer-events: auto;
}

.overlay-inner {
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
  transform-style: preserve-3d;
  -webkit-transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.12s;
}
.overlay-wrap.overlay-active .overlay-inner {
  transform: rotateY(180deg);
  -webkit-transform: rotateY(180deg);
}

.overlay-face {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 32rpx;
  overflow: hidden;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}
.overlay-front {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.overlay-back {
  transform: rotateY(180deg);
  -webkit-transform: rotateY(180deg);
  background: #fffdf9;
  display: flex;
  flex-direction: column;
  box-shadow: 0 24rpx 80rpx rgba(60, 40, 40, 0.22);
}

/* =======================================================
   分类背景染色
   ======================================================= */
.card-bg-vegetables { background-color: var(--bg-vegetables); }
.card-bg-fruits     { background-color: var(--bg-fruits);     }
.card-bg-grains     { background-color: var(--bg-grains);     }
.card-bg-meat       { background-color: var(--bg-meat);       }
.card-bg-dairy      { background-color: var(--bg-dairy);      }
.card-bg-legumes    { background-color: var(--bg-legumes);    }
.card-bg-nuts       { background-color: var(--bg-nuts);       }
.card-bg-spices     { background-color: var(--bg-spices);     }

/* =======================================================
   食物网格 & 正面卡片
   ======================================================= */
.grid-wrap { padding: 0 20rpx; }
.food-grid { display: flex; flex-direction: row; flex-wrap: wrap; gap: 20rpx; }

.food-card {
  width: calc((100% - 40rpx) / 3);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx 16rpx;
  border-radius: var(--card-radius);
  box-shadow: var(--card-shadow);
  box-sizing: border-box;
}

.food-emoji       { font-size: 56rpx; line-height: 1; margin-bottom: 10rpx; }
.food-emoji.large { font-size: 80rpx; }
.food-name  { font-size: 26rpx; font-weight: 600; color: var(--text-primary); text-align: center; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 4rpx; }
.food-en    { font-size: 20rpx; color: var(--text-en); text-align: center; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 14rpx; }

.dots-row { display: flex; flex-direction: row; align-items: center; gap: 10rpx; }
.dot       { width: 18rpx; height: 18rpx; border-radius: 50%; flex-shrink: 0; }
.dot-empty  { background-color: var(--dot-empty); }
.dot-rose   { background-color: var(--dot-rose);  box-shadow: 0 0 0 2rpx rgba(212,144,140,.25); }
.dot-amber  { background-color: var(--dot-amber); box-shadow: 0 0 0 2rpx rgba(212,184,120,.25); }
.dot-sage   { background-color: var(--dot-sage);  box-shadow: 0 0 0 2rpx rgba(138,180,138,.25); }

/* =======================================================
   背面：标题区
   ======================================================= */
.back-header {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx 24rpx;
  gap: 18rpx;
  flex-shrink: 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}
.back-emoji { font-size: 64rpx; line-height: 1; flex-shrink: 0; }
.back-title-group { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.back-name { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }
.back-en   { font-size: 24rpx; color: var(--text-en); font-style: italic; }
.back-close {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  background: rgba(0,0,0,0.07);
  font-size: 28rpx; color: var(--text-secondary); flex-shrink: 0;
}

/* =======================================================
   背面：主体区（可滚动）
   ======================================================= */
.back-body {
  flex: 1;
  padding: 24rpx 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  overflow-y: auto;
}

.back-section { display: flex; flex-direction: column; }

.section-header { display: flex; align-items: baseline; gap: 12rpx; margin-bottom: 16rpx; }
.section-title  { font-size: 26rpx; font-weight: 700; color: var(--text-secondary); letter-spacing: 1rpx; }
.section-hint   { font-size: 22rpx; color: var(--text-en); }

/* =======================================================
   喂食记录槽
   ======================================================= */
.slots-wrap { display: flex; flex-direction: column; gap: 14rpx; }

.slot {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  transition: background 0.15s;
  min-height: 88rpx;
}

/* 未记录：虚线边框提示可点击 */
.slot-pending {
  background: rgba(255,255,255,0.6);
  border: 1.5rpx dashed rgba(0,0,0,0.18);
}

/* 已记录：实线边框，稍深背景 */
.slot-done {
  background: rgba(255,255,255,0.85);
  border: 1.5rpx solid rgba(0,0,0,0.07);
}

/* 数字徽章 */
.slot-badge {
  width: 52rpx; height: 52rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 700; color: #fff;
  flex-shrink: 0;
}
.slot-badge-empty    { background: #c4bcb8; }
.slot-badge-safe     { background: var(--dot-sage);  }
.slot-badge-caution  { background: var(--dot-amber); }
.slot-badge-allergic { background: var(--dot-rose);  }

.slot-content { flex: 1; display: flex; flex-direction: column; gap: 6rpx; min-width: 0; }
.slot-label   { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }

/* date row (shown after recording) */
.slot-date-wrap { display: flex; align-items: center; gap: 8rpx; }
.slot-date      { font-size: 26rpx; color: var(--text-secondary); }
.slot-date-edit { font-size: 22rpx; color: var(--text-en); }

.slot-meta      { font-size: 26rpx; color: var(--text-secondary); }
.slot-meta-hint { color: var(--text-en); }

/* "+" 提示图标（未记录时） */
.slot-add { font-size: 36rpx; color: var(--text-en); flex-shrink: 0; width: 36rpx; text-align: center; }

/* =======================================================
   结果标签（已记录后右侧显示，点击展开选择器）
   ======================================================= */
.type-tag {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.type-tag-safe     { background: rgba(138, 180, 138, 0.18); color: #6a9a6a; }
.type-tag-caution  { background: rgba(212, 184, 120, 0.22); color: #a88040; }
.type-tag-allergic { background: rgba(212, 144, 140, 0.20); color: #b05050; }

/* =======================================================
   展开后的三选一选择器
   ======================================================= */
.type-options-row {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
  flex-shrink: 0;
}

.type-opt {
  padding: 10rpx 18rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: 1.5rpx solid transparent;
  transition: all 0.12s;
}

/* unselected */
.type-opt-safe     { color: #6a9a6a; border-color: rgba(138,180,138,0.45); background: rgba(138,180,138,0.08); }
.type-opt-caution  { color: #a88040; border-color: rgba(212,184,120,0.45); background: rgba(212,184,120,0.10); }
.type-opt-allergic { color: #b05050; border-color: rgba(212,144,140,0.45); background: rgba(212,144,140,0.08); }

/* selected (active) */
.type-opt-active-safe     { background: rgba(138,180,138,0.26); border-color: rgba(138,180,138,0.7); }
.type-opt-active-caution  { background: rgba(212,184,120,0.32); border-color: rgba(212,184,120,0.75); }
.type-opt-active-allergic { background: rgba(212,144,140,0.28); border-color: rgba(212,144,140,0.7); }

/* =======================================================
   喜好程度
   ======================================================= */
.like-scale { display: flex; flex-direction: row; gap: 10rpx; margin-top: 12rpx; }
.like-btn {
  flex: 1;
  height: 96rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 46rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.6);
  border: 1.5rpx solid rgba(0,0,0,0.06);
  transition: transform 0.12s, background 0.12s, border-color 0.12s;
}
.like-btn.like-active {
  background: rgba(196, 168, 176, 0.22);
  border-color: rgba(196, 168, 176, 0.6);
  transform: scale(1.12);
}

/* =======================================================
   备注输入
   ======================================================= */
.note-input {
  width: 100%;
  min-height: 100rpx;
  background: rgba(255,255,255,0.7);
  border: 1.5rpx solid rgba(0,0,0,0.07);
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  margin-top: 12rpx;
}
.note-placeholder { color: var(--text-en); font-size: 30rpx; }

/* =======================================================
   ===== DEV ONLY: debug 填充按钮 =====
   ======================================================= */
.debug-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  border: 2rpx dashed #c8c0bc;
  background: transparent;
}
.debug-btn-text { font-size: 22rpx; color: #b0a8a4; letter-spacing: 1rpx; }
/* ===== /DEV ONLY ===== */

/* =======================================================
   保存按钮（固定在 overlay-back 底部）
   ======================================================= */
.back-footer {
  padding: 16rpx 28rpx 28rpx;
  flex-shrink: 0;
  border-top: 1rpx solid rgba(0,0,0,0.05);
  background: #fffdf9;
  border-radius: 0 0 32rpx 32rpx;
}
.save-btn {
  width: 100%;
  padding: 28rpx 0;
  border-radius: 20rpx;
  background: #b09098;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 2rpx;
}

/* =======================================================
   空状态
   ======================================================= */
.empty-state { width: 100%; padding: 100rpx 0; display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.empty-emoji { font-size: 80rpx; }
.empty-text  { font-size: 28rpx; color: var(--text-secondary); }
