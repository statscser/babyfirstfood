/* =======================================================
   index.wxss — 莫兰迪色系 + Overlay 3D 翻转容器 + 食物网格
   ======================================================= */

.page {
  min-height: 100vh;
  background-color: var(--bg-page);
  padding-bottom: 60rpx;
}

/* =======================================================
   顶部标题栏
   ======================================================= */
.header {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx 20rpx;
  background-color: var(--header-bg);
  gap: 16rpx;
}
.header-sparkle { font-size: 36rpx; line-height: 1; }
.header-text    { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.header-title   { font-size: 40rpx; font-weight: 700; color: var(--text-primary); letter-spacing: 2rpx; }
.header-sub     { font-size: 22rpx; color: var(--text-en); letter-spacing: 1rpx; font-style: italic; }
.header-badge   { display: flex; align-items: baseline; background-color: var(--header-pink); border-radius: 40rpx; padding: 8rpx 20rpx; gap: 2rpx; }
.header-badge-num   { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }
.header-badge-total { font-size: 22rpx; color: var(--text-secondary); }

/* =======================================================
   搜索栏
   ======================================================= */
.search-wrap { padding: 16rpx 24rpx 8rpx; background-color: var(--header-bg); }
.search-bar  { display: flex; align-items: center; background-color: #f0ebe8; border-radius: 40rpx; padding: 16rpx 24rpx; gap: 12rpx; }
.search-icon  { font-size: 28rpx; opacity: 0.6; flex-shrink: 0; }
.search-input { flex: 1; font-size: 28rpx; color: var(--text-primary); background: transparent; }
.search-placeholder { color: var(--text-en); font-size: 28rpx; }
.search-clear { font-size: 24rpx; color: var(--text-secondary); padding: 4rpx 8rpx; flex-shrink: 0; }

/* =======================================================
   分类 Tab
   ======================================================= */
.tabs-scroll  { background-color: var(--header-bg); padding-bottom: 16rpx; white-space: nowrap; }
.tabs-inner   { display: flex; flex-direction: row; padding: 12rpx 24rpx 0; gap: 16rpx; }
.tab-item     { display: inline-flex; align-items: center; justify-content: center; padding: 12rpx 28rpx; border-radius: 40rpx; border: 2rpx solid #e0d8d4; background-color: var(--bg-card); flex-shrink: 0; transition: all 0.2s; }
.tab-label    { font-size: 26rpx; color: var(--text-secondary); font-weight: 500; }
.tab-active .tab-label { color: #ffffff; font-weight: 600; }

/* =======================================================
   数量提示
   ======================================================= */
.count-bar  { padding: 16rpx 32rpx 8rpx; }
.count-text { font-size: 24rpx; font-weight: 500; letter-spacing: 1rpx; }

/* =======================================================
   遮罩
   ======================================================= */
.mask      { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(30, 20, 20, 0.5); z-index: 100; }
.mask-show { display: block; }

/* =======================================================
   Overlay 3D 容器 — scale + flip（内容由 food-detail 组件提供）
   ======================================================= */
.overlay-wrap {
  position: fixed;
  top: 4vh;
  left: 5vw;
  width: 90vw;
  height: 90vh;
  z-index: 200;
  border-radius: 32rpx;
  perspective: 1400rpx;
  transform: scale(0.15);
  opacity: 0;
  pointer-events: none;
  transition:
    transform 0.46s cubic-bezier(0.22, 1, 0.36, 1),
    opacity   0.24s ease;
}
.overlay-wrap.overlay-active {
  transform: scale(1);
  opacity: 1;
  pointer-events: auto;
}

.overlay-inner {
  width: 100%;
  height: 100%;
  border-radius: 32rpx;
  transform-style: preserve-3d;
  -webkit-transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1) 0.12s;
}
.overlay-wrap.overlay-active .overlay-inner {
  transform: rotateY(180deg);
  -webkit-transform: rotateY(180deg);
}

.overlay-face {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  border-radius: 32rpx;
  overflow: hidden;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}
.overlay-front {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}
.overlay-back {
  transform: rotateY(180deg);
  -webkit-transform: rotateY(180deg);
  background: #fffdf9;
  display: flex;
  flex-direction: column;
  box-shadow: 0 24rpx 80rpx rgba(60, 40, 40, 0.22);
}

/* =======================================================
   食物网格卡片（正面，仅用于网格展示）
   ======================================================= */
.card-bg-vegetables { background-color: var(--bg-vegetables); }
.card-bg-fruits     { background-color: var(--bg-fruits);     }
.card-bg-grains     { background-color: var(--bg-grains);     }
.card-bg-meat       { background-color: var(--bg-meat);       }
.card-bg-dairy      { background-color: var(--bg-dairy);      }
.card-bg-legumes    { background-color: var(--bg-legumes);    }
.card-bg-nuts       { background-color: var(--bg-nuts);       }
.card-bg-spices     { background-color: var(--bg-spices);     }

.grid-wrap { padding: 0 20rpx; }
.food-grid { display: flex; flex-direction: row; flex-wrap: wrap; gap: 20rpx; }

.food-card {
  width: calc((100% - 40rpx) / 3);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx 16rpx;
  border-radius: var(--card-radius);
  box-shadow: var(--card-shadow);
  box-sizing: border-box;
}

.food-emoji       { font-size: 56rpx; line-height: 1; margin-bottom: 10rpx; }
.food-emoji.large { font-size: 80rpx; }
.food-name  { font-size: 26rpx; font-weight: 600; color: var(--text-primary); text-align: center; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 4rpx; }
.food-en    { font-size: 20rpx; color: var(--text-en); text-align: center; width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 14rpx; }

.dots-row { display: flex; flex-direction: row; align-items: center; gap: 10rpx; }
.dot       { width: 18rpx; height: 18rpx; border-radius: 50%; flex-shrink: 0; }
.dot-empty  { background-color: var(--dot-empty); }
.dot-rose   { background-color: var(--dot-rose);  box-shadow: 0 0 0 2rpx rgba(212,144,140,.25); }
.dot-amber  { background-color: var(--dot-amber); box-shadow: 0 0 0 2rpx rgba(212,184,120,.25); }
.dot-sage   { background-color: var(--dot-sage);  box-shadow: 0 0 0 2rpx rgba(138,180,138,.25); }

/* =======================================================
   空状态
   ======================================================= */
.empty-state { width: 100%; padding: 100rpx 0; display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.empty-emoji { font-size: 80rpx; }
.empty-text  { font-size: 28rpx; color: var(--text-secondary); }
