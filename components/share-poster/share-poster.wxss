/* components/share-poster/share-poster.wxss */

.sp-canvas-hidden {
  position: fixed;
  left: -9999rpx;
  top: 0;
  width: 375rpx;
  height: 720rpx;
  pointer-events: none;
}

/* ── Overlay ── */
.sp-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  z-index: 600;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}
.sp-overlay-bg {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: rgba(20, 12, 12, 0.6);
}

/* ── Panel ── */
.sp-panel {
  position: relative;
  width: 100%;
  max-height: 92vh;
  background: #fdf8f5;
  border-radius: 40rpx 40rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ── Baby name row ── */
.sp-name-row {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx 20rpx;
  gap: 16rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
  flex-shrink: 0;
}
.sp-name-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}
.sp-name-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  background: rgba(0,0,0,0.03);
  border-radius: 12rpx;
  padding: 10rpx 16rpx;
  box-sizing: border-box;
}
.sp-name-ph { color: var(--text-en); font-size: 26rpx; }

/* ── Scrollable body ── */
.sp-body {
  flex: 1;
  padding: 0 20rpx;
  box-sizing: border-box;
}

/* Loading state */
.sp-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 100rpx 0;
}
.sp-loading-icon { font-size: 72rpx; line-height: 1; }
.sp-loading-text { font-size: 30rpx; color: var(--text-secondary); }

/* Image preview */
.sp-img-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0 24rpx;
}
.sp-img {
  width: 100%;
  border-radius: 20rpx;
  display: block;
}
.sp-hint {
  font-size: 22rpx;
  color: var(--text-en);
  text-align: center;
}

/* Empty placeholder */
.sp-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 100rpx 0;
}
.sp-ph-emoji { font-size: 80rpx; line-height: 1; }
.sp-ph-text  { font-size: 28rpx; color: var(--text-secondary); }

/* ── Action buttons ── */
.sp-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  padding: 16rpx 24rpx 40rpx;
  flex-shrink: 0;
}
.sp-btn {
  flex: 1;
  padding: 22rpx 0;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 1rpx;
}
.sp-btn-cancel {
  background: rgba(0,0,0,0.05);
  color: var(--text-secondary);
}
.sp-btn-regen {
  background: rgba(196,168,176,0.12);
  color: #b09098;
  border: 1.5rpx solid rgba(196,168,176,0.4);
}
.sp-btn-save {
  background: #b09098;
  color: #fff;
}
.sp-btn-share {
  background: #8fab8f;
  color: #fff;
}
