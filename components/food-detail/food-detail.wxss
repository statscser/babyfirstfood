/* =======================================================
   food-detail.wxss — 背面详情 + 记录交互样式
   ======================================================= */

/* Host element must fill overlay-back; without this, height: 100% on fd-root resolves to 0 */
:host {
  display: block;
  width: 100%;
  height: 100%;
}

/* 组件根节点撑满父容器（overlay-back） */
.fd-root {
  position: relative;
  overflow: hidden;    /* prevent footer from escaping overlay-face bounds */
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* =======================================================
   分类背景染色（CSS 变量来自 app.wxss，组件内可用）
   ======================================================= */
.card-bg-vegetables { background-color: var(--bg-vegetables); }
.card-bg-fruits     { background-color: var(--bg-fruits);     }
.card-bg-grains     { background-color: var(--bg-grains);     }
.card-bg-meat       { background-color: var(--bg-meat);       }
.card-bg-dairy      { background-color: var(--bg-dairy);      }
.card-bg-legumes    { background-color: var(--bg-legumes);    }
.card-bg-nuts       { background-color: var(--bg-nuts);       }
.card-bg-spices     { background-color: var(--bg-spices);     }

/* =======================================================
   标题区
   ======================================================= */
.back-header {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx 24rpx;
  gap: 18rpx;
  flex-shrink: 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}
.back-emoji { font-size: 64rpx; line-height: 1; flex-shrink: 0; }
.back-title-group { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.back-name { font-size: 36rpx; font-weight: 700; color: var(--text-primary); }
.back-en   { font-size: 24rpx; color: var(--text-en); font-style: italic; }
.back-close {
  width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
  background: rgba(0,0,0,0.07);
  font-size: 28rpx; color: var(--text-secondary); flex-shrink: 0;
}

/* =======================================================
   主体区（可滚动）
   ======================================================= */
.back-body {
  flex: 1;
  min-height: 0;
  padding: 24rpx 28rpx 16rpx;
  box-sizing: border-box;
  /* Block layout (no display:flex) lets sections grow naturally and overflow
     the scroll-view, which is the only reliable way to trigger scroll in WeChat Mini Program.
     With flex-column, children shrink to fit instead of overflowing → no scroll. */
}

.back-section {
  display: flex;
  flex-direction: column;
  margin-bottom: 32rpx;  /* replaces the parent gap:32rpx that was removed */
}

.section-header { display: flex; align-items: baseline; gap: 12rpx; margin-bottom: 16rpx; }
.section-title  { font-size: 26rpx; font-weight: 700; color: var(--text-secondary); letter-spacing: 1rpx; }
.section-hint   { font-size: 22rpx; color: var(--text-en); }

/* =======================================================
   喂食记录槽
   ======================================================= */
.slots-wrap { display: flex; flex-direction: column; gap: 14rpx; }

.slot {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  transition: background 0.15s;
  min-height: 88rpx;
}
.slot-pending {
  background: rgba(255,255,255,0.6);
  border: 1.5rpx dashed rgba(0,0,0,0.18);
}
.slot-done {
  background: rgba(255,255,255,0.85);
  border: 1.5rpx solid rgba(0,0,0,0.07);
}

.slot-badge {
  width: 52rpx; height: 52rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 700; color: #fff;
  flex-shrink: 0;
}
.slot-badge-empty    { background: #c4bcb8; }
.slot-badge-safe     { background: var(--dot-sage);  }
.slot-badge-caution  { background: var(--dot-amber); }
.slot-badge-allergic { background: var(--dot-rose);  }

.slot-content   { flex: 1; display: flex; flex-direction: column; gap: 6rpx; min-width: 0; }
.slot-label     { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.slot-date-wrap { display: flex; align-items: center; gap: 8rpx; border-radius: 10rpx; padding: 2rpx 6rpx; }
.slot-date      { font-size: 26rpx; color: var(--text-secondary); }
.slot-date-edit { font-size: 22rpx; color: var(--text-en); }

/* Pulsing highlight after date-order warning — draws eye to the tappable picker */
@keyframes date-pulse {
  0%   { background: rgba(212, 144, 140, 0.0);  border-color: rgba(212, 144, 140, 0.0); }
  40%  { background: rgba(212, 144, 140, 0.22); border-color: rgba(212, 144, 140, 0.7); }
  100% { background: rgba(212, 144, 140, 0.12); border-color: rgba(212, 144, 140, 0.5); }
}
.date-pending {
  border: 1.5rpx solid rgba(212, 144, 140, 0.5);
  background: rgba(212, 144, 140, 0.12);
  animation: date-pulse 0.5s ease-out forwards;
}
.date-pending .slot-date      { color: #b05050; font-weight: 600; }
.date-pending .slot-date-edit { color: #b05050; }
.slot-meta      { font-size: 26rpx; color: var(--text-secondary); }
.slot-meta-hint { color: var(--text-en); }

.slot-add { font-size: 36rpx; color: var(--text-en); flex-shrink: 0; width: 36rpx; text-align: center; }

/* =======================================================
   结果标签（折叠态，点击展开）
   ======================================================= */
.type-tag {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
}
.type-tag-safe     { background: rgba(138, 180, 138, 0.18); color: #6a9a6a; }
.type-tag-caution  { background: rgba(212, 184, 120, 0.22); color: #a88040; }
.type-tag-allergic { background: rgba(212, 144, 140, 0.20); color: #b05050; }

/* =======================================================
   三选一展开选择器
   ======================================================= */
.type-options-row {
  display: flex;
  flex-direction: row;
  gap: 10rpx;
  flex-shrink: 0;
}
.type-opt {
  padding: 10rpx 18rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  border: 1.5rpx solid transparent;
  transition: all 0.12s;
}
.type-opt-safe     { color: #6a9a6a; border-color: rgba(138,180,138,0.45); background: rgba(138,180,138,0.08); }
.type-opt-caution  { color: #a88040; border-color: rgba(212,184,120,0.45); background: rgba(212,184,120,0.10); }
.type-opt-allergic { color: #b05050; border-color: rgba(212,144,140,0.45); background: rgba(212,144,140,0.08); }
.type-opt-active-safe     { background: rgba(138,180,138,0.26); border-color: rgba(138,180,138,0.7); }
.type-opt-active-caution  { background: rgba(212,184,120,0.32); border-color: rgba(212,184,120,0.75); }
.type-opt-active-allergic { background: rgba(212,144,140,0.28); border-color: rgba(212,144,140,0.7); }

/* =======================================================
   跳过排敏开关
   ======================================================= */
.skip-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(139, 171, 143, 0.10);
  border: 1.5rpx solid rgba(139, 171, 143, 0.32);
  border-radius: 18rpx;
  padding: 20rpx 22rpx 20rpx 24rpx;
  margin-top: 12rpx;
  gap: 16rpx;
}
.skip-text-group { flex: 1; display: flex; flex-direction: column; gap: 6rpx; min-width: 0; }
.skip-label { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.skip-hint  { font-size: 22rpx; color: #7a9a7a; line-height: 1.55; }

/* =======================================================
   过敏症状入口行
   ======================================================= */
.symptom-entry {
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(212, 144, 140, 0.09);
  border: 1.5rpx solid rgba(212, 144, 140, 0.30);
  border-radius: 18rpx;
  padding: 18rpx 22rpx;
  margin-top: 12rpx;
  gap: 12rpx;
}
.symptom-entry-left  { flex: 1; display: flex; flex-direction: column; gap: 8rpx; min-width: 0; }
.symptom-entry-title { font-size: 28rpx; font-weight: 600; color: #b05050; }
.symptom-entry-hint  { font-size: 24rpx; color: #c09090; }
.symptom-entry-arrow { font-size: 40rpx; color: #c09090; flex-shrink: 0; line-height: 1; }
.symptom-chips-row   { display: flex; flex-wrap: wrap; gap: 8rpx; }
.symptom-chip {
  font-size: 22rpx; color: #b05050;
  background: rgba(212, 144, 140, 0.18);
  border-radius: 20rpx; padding: 4rpx 16rpx;
}

/* =======================================================
   过敏症状弹窗
   ======================================================= */
.symptom-modal-mask {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(30, 20, 20, 0.48);
  z-index: 50;
  display: flex; align-items: center; justify-content: center;
}
.symptom-modal {
  width: 560rpx;
  background: #fdf8f5;
  border-radius: 28rpx;
  padding: 40rpx 32rpx 28rpx;
  display: flex; flex-direction: column; gap: 0;
}
.symptom-modal-title {
  font-size: 32rpx; font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 24rpx;
}
.symptom-modal-list { display: flex; flex-direction: column; gap: 10rpx; }
.symptom-item {
  display: flex; align-items: center; gap: 18rpx;
  padding: 18rpx 24rpx;
  background: rgba(255, 255, 255, 0.65);
  border: 1.5rpx solid rgba(0, 0, 0, 0.07);
  border-radius: 18rpx;
}
.symptom-item-active {
  background: rgba(212, 144, 140, 0.10);
  border-color: rgba(212, 144, 140, 0.38);
}
.symptom-check {
  width: 44rpx; height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 0, 0, 0.18);
  background: rgba(255, 255, 255, 0.9);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.symptom-check-on   { background: #d4908c; border-color: #d4908c; }
.symptom-check-icon { font-size: 24rpx; color: #fff; font-weight: 700; line-height: 1; }
.symptom-label      { font-size: 30rpx; color: var(--text-primary); }
.symptom-modal-confirm {
  margin-top: 28rpx;
  background: #b09098;
  color: #fff;
  font-size: 32rpx; font-weight: 600;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 20rpx;
  letter-spacing: 2rpx;
}

/* =======================================================
   喜好程度
   ======================================================= */
.like-scale { display: flex; flex-direction: row; gap: 10rpx; margin-top: 12rpx; }
.like-btn {
  flex: 1;
  height: 96rpx;
  display: flex; align-items: center; justify-content: center;
  font-size: 46rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.6);
  border: 1.5rpx solid rgba(0,0,0,0.06);
  transition: transform 0.12s, background 0.12s, border-color 0.12s;
}
.like-btn.like-active {
  background: rgba(196, 168, 176, 0.22);
  border-color: rgba(196, 168, 176, 0.6);
  transform: scale(1.12);
}

/* =======================================================
   备注输入
   ======================================================= */
.note-input {
  width: 100%;
  min-height: 100rpx;
  background: rgba(255,255,255,0.7);
  border: 1.5rpx solid rgba(0,0,0,0.07);
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  margin-top: 12rpx;
}
.note-placeholder { color: var(--text-en); font-size: 30rpx; }


/* =======================================================
   保存按钮（底部固定）
   ======================================================= */
.back-footer {
  padding: 16rpx 28rpx 20rpx;
  flex-shrink: 0;
  border-top: 1rpx solid rgba(0,0,0,0.05);
  background: #fffdf9;
  border-radius: 0 0 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 0rpx;
}
.footer-buttons {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}
.delete-food-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 20rpx;
  padding-bottom: 8rpx;
}
.delete-food-text {
  font-size: 26rpx;
  color: #b05050;
  letter-spacing: 1rpx;
}
.reset-btn {
  width: 40%;
  padding: 18rpx 0;
  border-radius: 20rpx;
  border: 1.5rpx solid rgba(176, 80, 80, 0.3);
  background: rgba(176, 80, 80, 0.05);
  color: #b05050;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  letter-spacing: 1rpx;
}
.save-btn {
  width: 40%;
  padding: 28rpx 0;
  border-radius: 20rpx;
  background: #b09098;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 2rpx;
}
